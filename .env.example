# mBot Studio Environment Configuration
# Copy this file to .env and fill in your values

# GitHub Token (for Copilot AI integration via GitHub Models)
# Create a personal access token at https://github.com/settings/tokens
# Required scope: models:read
GITHUB_TOKEN=your_github_token_here

# AI Model fallback (used only if auto-detection fails)
# On startup, the server auto-selects the best available OpenAI model from your account
# Model IDs use publisher/name format, e.g. openai/gpt-5-chat
AI_MODEL=openai/gpt-5-chat
AI_BASE_URL=https://models.github.ai/inference

# Optional local/offline AI mode for debugging Program page without GitHub Models
# When true, /api/ai endpoints use a deterministic local generator instead of cloud AI
AI_LOCAL_DEBUG=false

# MQTT Broker Settings (for robot communication)
# Point this to your external Mosquitto server on the network
MQTT_BROKER_URL=mqtt://your-mqtt-server:1883
MQTT_TOPIC_PREFIX=mbot-studio

# Server Settings
HOST=0.0.0.0
PORT=3001

# Data directory for persistent config (Docker: set to /app/data)
# DATA_DIR=/app/data

# WiFi Settings (for mBot2 firmware configuration)
WIFI_SSID=your_wifi_name
WIFI_PASSWORD=your_wifi_password
